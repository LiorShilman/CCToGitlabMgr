<UserControl x:Class="CCToGitlabMgr.Views.ConfigStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionTitle}">
            <Run Text="01" Foreground="{StaticResource AccentBrush}" FontSize="24"/>
            <Run Text="  Git Config — Global Settings"/>
        </TextBlock>
        <TextBlock Style="{StaticResource SectionDesc}" Text="Set up your global Git identity and recommended settings. Run once per machine."/>

        <!-- Card: Identity -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Git Identity" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,16"/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="User Name (must match GitLab)"/>
                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding Context.UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Email (must match GitLab)"/>
                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding Context.UserEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
            </StackPanel>
        </Border>

        <!-- Card: Settings -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Recommended Settings" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,16"/>

                <CheckBox Style="{StaticResource DarkCheckBox}" IsChecked="{Binding Context.AutoCrlf}" Margin="0,0,0,10">
                    <TextBlock>
                        <Run Text="core.autocrlf = true" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentHiBrush}"/>
                        <Run Text="  (CRLF on checkout, LF in repo — for Windows)" Foreground="{StaticResource Text2Brush}"/>
                    </TextBlock>
                </CheckBox>

                <CheckBox Style="{StaticResource DarkCheckBox}" IsChecked="{Binding Context.LongPaths}" Margin="0,0,0,10">
                    <TextBlock>
                        <Run Text="core.longpaths = true" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentHiBrush}"/>
                        <Run Text="  (required for .NET projects)" Foreground="{StaticResource Text2Brush}"/>
                    </TextBlock>
                </CheckBox>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Default branch name:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding Context.DefaultBranch, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Apply Button -->
        <Button Content="Apply Git Configuration" Command="{Binding ApplyGitConfigCommand}"
                Style="{StaticResource AccentButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>

        <!-- Warning -->
        <Border Background="#14FBBF24" BorderBrush="#4DFBBF24" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="!" FontWeight="Bold" Foreground="{StaticResource WarnBrush}" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Top"/>
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Text1Brush}" FontSize="13">
                    <Run FontWeight="Bold" Foreground="{StaticResource Text0Brush}">core.autocrlf=true </Run>
                    <Run>is essential for Windows. Without it, Visual Studio will mark all files as &quot;changed&quot; after clone due to line ending differences.</Run>
                </TextBlock>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
