<UserControl x:Class="CCToGitlabMgr.Views.VerifyStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionTitle}">
            <Run Text="07" Foreground="{StaticResource AccentBrush}" FontSize="24"/>
            <Run Text="  Verify — Fresh Clone Test"/>
        </TextBlock>
        <TextBlock Style="{StaticResource SectionDesc}" Text="Clone from GitLab to a fresh folder and verify Build + Run."/>

        <!-- Clone Test -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Fresh Clone Verification" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,12"/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Verify folder (separate from staging):"/>
                <DockPanel Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right" Content="Browse..." Command="{Binding BrowseVerifyCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="14,8"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding Context.VerifyPath, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>

                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,4">
                    <Run Text="Remote URL: "/>
                    <Run Text="{Binding Context.RemoteUrl, Mode=OneWay}" Foreground="{StaticResource AccentHiBrush}" FontFamily="{StaticResource MonoFont}"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,16">
                    <Run Text="Will clone to: "/>
                    <Run Text="{Binding Context.ProjectName, Mode=OneWay}" Foreground="{StaticResource Text1Brush}"/>
                </TextBlock>

                <Button Content="Clone and Verify" Command="{Binding RunVerifyCommand}"
                        Style="{StaticResource AccentButton}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Manual Steps -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Manual Build Test" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,16"/>
                <StackPanel Margin="0,0,0,4">
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">1.</Run>
                        <Run>  Open the .sln in the correct Visual Studio version</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">2.</Run>
                        <Run>  Allow NuGet package restore if prompted</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">3.</Run>
                        <Run>  Build > Clean Solution, then Build > Rebuild Solution</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">4.</Run>
                        <Run>  Verify: 0 errors, warnings look normal</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,4">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">5.</Run>
                        <Run>  Run the project (F5) — verify normal behavior</Run>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Warning -->
        <Border Background="#14FBBF24" BorderBrush="#4DFBBF24" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,0,16">
            <DockPanel>
                <TextBlock Text="!" FontWeight="Bold" Foreground="{StaticResource WarnBrush}" FontSize="18"
                           DockPanel.Dock="Left" Margin="0,2,14,0" VerticalAlignment="Top"/>
                <StackPanel>
                    <TextBlock Text="If Build fails after clone" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" FontSize="13" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="{StaticResource WarnBrush}">1.</Run>
                            <Run xml:space="preserve">  A required file was excluded by </Run><Run FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentHiBrush}">.gitignore</Run>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="20,2,0,0" TextWrapping="Wrap"
                                   Text="Edit .gitignore and add an exception for the missing file, then commit and push."/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="{StaticResource WarnBrush}">2.</Run>
                            <Run xml:space="preserve">  External DLL references are missing</Run>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="20,2,0,0" TextWrapping="Wrap"
                                   Text="Add them to a libs/ folder with a gitignore exception, or switch to NuGet packages."/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Version Tags -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Version Tags" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="Create a Git tag to mark this version. Tags appear as releases in GitLab under Deploy > Releases."/>

                <!-- Tag Name -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="Tag Name:"/>
                <TextBox Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"
                         Text="{Binding TagName, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{StaticResource MonoFont}"/>

                <!-- Tag Message -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="Tag Message (optional):"/>
                <TextBox Style="{StaticResource DarkTextBox}" Margin="0,0,0,16"
                         Text="{Binding TagMessage, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{StaticResource MonoFont}"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Create Tag" Command="{Binding CreateTagCommand}"
                            Style="{StaticResource AccentButton}" Padding="14,7" Margin="0,0,8,0" FontSize="12"/>
                    <Button Content="Push Tags to GitLab" Command="{Binding PushTagsCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,7" Margin="0,0,8,0" FontSize="12"
                            BorderBrush="{StaticResource OkBrush}"/>
                    <Button Content="List Tags" Command="{Binding ListTagsCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,7" FontSize="12"/>
                </StackPanel>

                <!-- Tip -->
                <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,12,0,0" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold">Tip:</Run>
                    <Run xml:space="preserve"> Use semantic versioning — v1.0.0 for the initial migration, v1.0.1 for fixes, v1.1.0 for new features.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Post-migration config -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Post-Migration GitLab Config" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Protected Branches" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,12"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Settings > Repository > Protected Branches — protect main"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Default Branch" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,12"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Verify main is set as default"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Merge Requests" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,12"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Require approvals if working in a team"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="CI/CD" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,12"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Add .gitlab-ci.yml for automated builds (optional)"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="README" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,4"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Update with build instructions and link to old ClearCase archive"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
