<UserControl x:Class="CCToGitlabMgr.Views.VerifyStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionTitle}">
            <Run Text="07" Foreground="{StaticResource AccentBrush}" FontSize="24"/>
            <Run Text="  Verify — Fresh Clone Test"/>
        </TextBlock>
        <TextBlock Style="{StaticResource SectionDesc}" Text="Clone from remote to a fresh folder and verify Build + Run."/>

        <!-- Clone Test -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Fresh Clone Verification" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,12"/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Verify folder (separate from staging):"/>
                <DockPanel Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Content="Browse..." Command="{Binding BrowseVerifyCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="14,8"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding Context.VerifyPath, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>
                <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold">Parent folder only.</Run>
                    <Run xml:space="preserve">  The project is cloned into a subfolder named </Run>
                    <Run Text="{Binding Context.ProjectName, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentHiBrush}"/>
                    <Run xml:space="preserve">  inside it.  Example: </Run>
                    <Run FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentHiBrush}">C:\Work\Verify</Run>
                </TextBlock>

                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,4">
                    <Run Text="Remote URL: "/>
                    <Run Text="{Binding Context.RemoteUrl, Mode=OneWay}" Foreground="{StaticResource AccentHiBrush}" FontFamily="{StaticResource MonoFont}"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,16">
                    <Run Text="Will clone to: "/>
                    <Run Text="{Binding Context.ProjectName, Mode=OneWay}" Foreground="{StaticResource Text1Brush}"/>
                </TextBlock>

                <Button Content="Clone and Verify" Command="{Binding RunVerifyCommand}"
                        Style="{StaticResource AccentButton}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Fix & Re-push (when issues found during verify) -->
        <Border Style="{StaticResource CardBorder}" BorderBrush="{StaticResource WarnBrush}" BorderThickness="1">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="⚠" FontSize="16" Foreground="{StaticResource WarnBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Fix &amp; Re-push (if verification failed)" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16"
                           Text="Found missing files or a wrong .gitignore? Fix directly from the staging folder — no need to go to Daily Workflow."/>

                <!-- Step 1: Edit gitignore inline -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource AccentHiBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,6">
                            <Run Text="1."/>
                            <Run Text="  Edit .gitignore"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="Load the current .gitignore (or template), edit it here, then commit and push. Add '!' exceptions for files you want to force-include."/>
                        <Button Content="Load .gitignore into Editor" Command="{Binding VerifyFixGitignoreCommand}"
                                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Padding="14,7" FontSize="12" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding VerifyGitignoreContent, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource MonoFont}" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                 MinHeight="180" MaxHeight="320"/>
                    </StackPanel>
                </Border>

                <!-- Step 2: Commit and push -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource AccentHiBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,6">
                            <Run Text="2."/>
                            <Run Text="  Save .gitignore + Stage All + Commit + Push"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="Writes the editor content to .gitignore, stages all changes, commits and pushes."/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Commit Message:"/>
                        <TextBox Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"
                                 Text="{Binding VerifyFixCommitMessage, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Save .gitignore + Stage + Commit + Push" Command="{Binding VerifyFixCommitPushCommand}"
                                Style="{StaticResource AccentButton}" HorizontalAlignment="Left" Padding="14,7" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Step 3: Push Only (retry) -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource AccentHiBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,6">
                            <Run Text="3."/>
                            <Run Text="  Push Only (retry after failed push)"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="Use this if the commit succeeded but the push failed (e.g. file size limit). Runs git push without re-committing."/>
                        <Button Content="Push Only" Command="{Binding VerifyPushOnlyCommand}"
                                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Padding="14,7" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Step 4: Re-verify -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="14,10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource AccentHiBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,6">
                            <Run Text="4."/>
                            <Run Text="  Re-run Clone and Verify above"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" TextWrapping="Wrap"
                                   Text="After pushing, delete the old verify folder and click 'Clone and Verify' again to confirm the fix."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Remove accidentally tracked files -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Remove Accidentally Tracked Files" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,14"
                           Text="Scans the staging repo for files that are tracked by git but should be ignored by .gitignore. Select files to remove from git (files stay on disk)."/>

                <Button Content="Scan for Accidentally Tracked Files" Command="{Binding VerifyScanTrackedIgnoredCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                        Padding="14,8" FontSize="12" Margin="0,0,0,12"/>

                <!-- Results list -->
                <StackPanel Visibility="{Binding TrackedIgnoredFiles.Count, Converter={StaticResource CountToVis}}">

                    <!-- Select All header -->
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="10,7" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding AllTrackedIgnoredSelected, Mode=TwoWay}"
                                      Style="{StaticResource DarkCheckBox}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Select All" Foreground="{StaticResource Text2Brush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- File list -->
                    <ItemsControl ItemsSource="{Binding TrackedIgnoredFiles}" MaxHeight="250">
                        <ItemsControl.Template>
                            <ControlTemplate>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4"
                                        Padding="10,6" Margin="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"
                                                  Style="{StaticResource DarkCheckBox}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding FilePath}" VerticalAlignment="Center"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                   Foreground="{StaticResource DangerBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Remove Selected from Git (keep files locally)"
                            Command="{Binding VerifyRemoveCachedCommand}"
                            Style="{StaticResource DangerButton}" HorizontalAlignment="Left"
                            Padding="14,8" FontSize="12" Margin="0,10,0,0"/>

                    <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="After removing, use 'Stage All + Commit + Push' in the Fix card above to update the remote."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Force-add files with ! exception -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Add Files with ! Exception" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,14"
                           Text="Scans .gitignore for negation lines (!pattern) and finds matching files on disk that are not yet tracked by git. Use this after adding a ! exception for a missing file."/>

                <Button Content="Scan for ! Exception Files" Command="{Binding VerifyScanExceptionFilesCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                        Padding="14,8" FontSize="12" Margin="0,0,0,12"/>

                <StackPanel Visibility="{Binding ExceptionFiles.Count, Converter={StaticResource CountToVis}}">

                    <!-- Select All header -->
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="10,7" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding AllExceptionFilesSelected, Mode=TwoWay}"
                                      Style="{StaticResource DarkCheckBox}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Select All" Foreground="{StaticResource Text2Brush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- File list -->
                    <ItemsControl ItemsSource="{Binding ExceptionFiles}" MaxHeight="250">
                        <ItemsControl.Template>
                            <ControlTemplate>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4"
                                        Padding="10,6" Margin="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"
                                                  Style="{StaticResource DarkCheckBox}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding DisplayPath}" VerticalAlignment="Center"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                   Foreground="{Binding IsDirectory, Converter={StaticResource BoolToVis},
                                                               ConverterParameter=Invert,
                                                               FallbackValue={StaticResource AccentHiBrush}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource WarnBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentHiBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Force-Add Selected (git add -f)"
                            Command="{Binding VerifyForceAddExceptionCommand}"
                            Style="{StaticResource AccentButton}" HorizontalAlignment="Left"
                            Padding="14,8" FontSize="12" Margin="0,10,0,0"/>

                    <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                               Text="After adding, use 'Stage All + Commit + Push' in the Fix card above to push to remote."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Manual Steps -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Manual Build Test" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,16"/>
                <StackPanel Margin="0,0,0,4">
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">1.</Run>
                        <Run>  Open the .sln in the correct Visual Studio version</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">2.</Run>
                        <Run>  Allow NuGet package restore if prompted</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">3.</Run>
                        <Run>  Build > Clean Solution, then Build > Rebuild Solution</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">4.</Run>
                        <Run>  Verify: 0 errors, warnings look normal</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,4">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">5.</Run>
                        <Run>  Run the project (F5) — verify normal behavior</Run>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Warning -->
        <Border Background="#14FBBF24" BorderBrush="#4DFBBF24" BorderThickness="1" CornerRadius="8" Padding="18,14" Margin="0,0,0,16">
            <DockPanel>
                <TextBlock Text="!" FontWeight="Bold" Foreground="{StaticResource WarnBrush}" FontSize="18"
                           DockPanel.Dock="Left" Margin="0,2,14,0" VerticalAlignment="Top"/>
                <StackPanel>
                    <TextBlock Text="If Build fails after clone" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" FontSize="13" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="{StaticResource WarnBrush}">1.</Run>
                            <Run xml:space="preserve">  A required file was excluded by </Run><Run FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentHiBrush}">.gitignore</Run>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="20,2,0,0" TextWrapping="Wrap"
                                   Text="Edit .gitignore and add an exception for the missing file, then commit and push."/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="{StaticResource WarnBrush}">2.</Run>
                            <Run xml:space="preserve">  External DLL references are missing</Run>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="20,2,0,0" TextWrapping="Wrap"
                                   Text="Add them to a libs/ folder with a gitignore exception, or switch to NuGet packages."/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Repo Inspector -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Repository Inspector" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,14"
                           Text="Analyse tracked files — total size, largest files, breakdown by extension."/>
                <Button Content="Inspect Staging Repo" Command="{Binding VerifyRepoInspectorCommand}"
                        Style="{StaticResource SecondaryButton}" Padding="16,8" FontSize="13" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Post-migration config -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Post-Migration Remote Config" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Protected Branches" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,12"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Settings > Repository > Protected Branches — protect main"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Default Branch" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,12"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Verify main is set as default"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Merge Requests" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,12"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Require approvals if working in a team"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="CI/CD" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,12"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Add CI/CD config for automated builds (optional)"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="README" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource AccentHiBrush}" Margin="0,0,16,4"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Update with build instructions and link to old ClearCase archive"
                               FontSize="13" Foreground="{StaticResource Text1Brush}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
