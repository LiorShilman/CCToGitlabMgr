<UserControl x:Class="CCToGitlabMgr.Views.DailyWorkflowStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionTitle}">
            <Run Text="09" Foreground="{StaticResource AccentBrush}" FontSize="24"/>
            <Run Text="  Daily Workflow — Ongoing Git Operations"/>
        </TextBlock>
        <TextBlock Style="{StaticResource SectionDesc}" Text="Day-to-day Git operations for your migrated project. Pull, commit, push, branch, and more."/>

        <!-- Working Directory Setup -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Working Directory" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,14"
                           Text="Choose the folder where you develop. Clone from the remote to a fresh directory — separate from the staging folder used during migration."/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Working folder:"/>
                <DockPanel Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Content="Browse..." Command="{Binding BrowseDailyWorkingCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="14,8"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding DailyWorkingPath, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MonoFont}"/>
                </DockPanel>
                <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold">If the folder is empty</Run><Run xml:space="preserve"> — clone goes directly into it.  </Run>
                    <Run FontWeight="SemiBold">If not empty</Run><Run xml:space="preserve"> — a subfolder named </Run>
                    <Run Text="{Binding Context.ProjectName, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource AccentHiBrush}"/>
                    <Run xml:space="preserve"> is created automatically.</Run>
                </TextBlock>

                <!-- Status indicator -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Status: " Foreground="{StaticResource Text2Brush}" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="&#x2713; Ready" Foreground="{StaticResource OkBrush}" FontSize="13" FontWeight="Bold"
                               Visibility="{Binding DailyWorkingDirIsReady, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding DailyWorkingDirStatus, Mode=OneWay}" Foreground="{StaticResource WarnBrush}" FontSize="13" FontWeight="SemiBold"
                               Visibility="{Binding DailyWorkingDirIsReady, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                </StackPanel>

                <!-- Current branch display -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12"
                            Visibility="{Binding CurrentBranchName, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="&#x2387; Branch: " Foreground="{StaticResource Text2Brush}" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentBranchName}" Foreground="#FF10B981" FontSize="13"
                               FontWeight="Bold" FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Remote URL display -->
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,12">
                    <Run Text="Remote URL: "/>
                    <Run Text="{Binding Context.RemoteUrl, Mode=OneWay}" Foreground="{StaticResource AccentHiBrush}" FontFamily="{StaticResource MonoFont}"/>
                </TextBlock>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Clone from Remote" Command="{Binding CloneToDailyCommand}"
                            Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Text3Brush}" FontSize="12"
                               Text="Clones into the selected folder using the Remote URL from Step 5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Quick Actions -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Quick Actions" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,14"
                           Text="Common Git operations on your working directory."/>
                <WrapPanel>
                    <Button Content="Fetch" Command="{Binding DailyFetchCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                    <Button Content="Pull (Get Latest)" Command="{Binding DailyPullCommand}"
                            Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                    <Button Content="Push to Remote" Command="{Binding DailyPushCommand}"
                            Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                    <Button Content="Status" Command="{Binding DailyStatusCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                    <Button Content="Diff" Command="{Binding DailyDiffCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                    <Button Content="Log (Recent)" Command="{Binding DailyLogCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Stage & Commit -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Stage and Commit" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,14"
                           Text="Stage all changes and create a commit. Write a clear, short commit message describing what changed."/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Commit Message:"/>
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding DailyCommitMessage, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="80"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="{StaticResource MonoFont}" FontSize="12"/>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Stage All + Commit" Command="{Binding DailyCommitCommand}"
                            Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                    <Button Content="Stage All + Commit + Push" Command="{Binding DailyCommitPushCommand}"
                            Style="{StaticResource AccentButton}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                    <Button Content="Amend Last Commit" Command="{Binding DailyAmendCommitCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" FontSize="12"/>
                </StackPanel>

                <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold">Tip:</Run>
                    <Run xml:space="preserve"> Write commit messages like "Fix login timeout bug" or "Add export-to-CSV feature". Keep the first line under 72 characters.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Undo / Reset -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Undo / Reset" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,14" TextWrapping="Wrap"
                           Text="Undo operations to fix mistakes. Use with care — some actions cannot be reversed."/>

                <WrapPanel>
                    <Button Content="Unstage All" Command="{Binding DailyUnstageCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                    <Button Content="Undo Last Commit" Command="{Binding DailyUndoCommitCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                    <Button Content="Discard All Changes" Command="{Binding DailyDiscardCommand}"
                            Style="{StaticResource DangerButton}" Padding="14,8" Margin="0,0,8,8" FontSize="12"/>
                </WrapPanel>

                <Border Background="#14EF4444" BorderBrush="#4DEF4444" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,8,0,0">
                    <DockPanel>
                        <TextBlock Text="!" FontWeight="Bold" Foreground="#FFEF4444" FontSize="16"
                                   DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="12" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">Unstage All</Run>
                                <Run xml:space="preserve"> — removes files from Staging Area, changes preserved</Run>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="12" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">Undo Last Commit</Run>
                                <Run xml:space="preserve"> — removes the commit, files stay staged (soft reset)</Run>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="12" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="#FFEF4444">Discard All Changes</Run>
                                <Run xml:space="preserve" Foreground="#FFEF4444"> — permanently deletes all uncommitted changes!</Run>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Branches -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Branches" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" VerticalAlignment="Center"/>
                    <!-- Current branch indicator -->
                    <Border DockPanel.Dock="Right" Background="#1410B981" BorderBrush="#4D10B981" BorderThickness="1"
                            CornerRadius="14" Padding="14,6" HorizontalAlignment="Right"
                            Visibility="{Binding CurrentBranchName, Converter={StaticResource NullToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2387;" Foreground="#FF10B981" FontSize="15" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Foreground="#FFADB5BD" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0" Text="ON"/>
                            <TextBlock Text="{Binding CurrentBranchName}" Foreground="#FF10B981" FontSize="13"
                                       FontWeight="Bold" FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,14"
                           Text="Create feature branches for isolated work, then merge back via Pull/Merge Requests."/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="New Branch Name:"/>
                <DockPanel Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right" Content="Create &amp; Switch" Command="{Binding DailyCreateBranchCommand}"
                            Style="{StaticResource AccentButton}" Margin="8,0,0,0" Padding="14,8" FontSize="12"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MonoFont}"/>
                </DockPanel>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Switch to Branch:"/>
                <DockPanel Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right" Content="Switch" Command="{Binding DailySwitchBranchCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="14,8" FontSize="12"/>
                    <Button DockPanel.Dock="Right" Content="&#x21BB;" Command="{Binding RefreshBranchListCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Padding="8,8" FontSize="14"
                            ToolTip="Refresh branch list"/>
                    <ComboBox Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding AvailableBranches}"
                              SelectedItem="{Binding SwitchBranchName, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFont}" FontSize="12"/>
                </DockPanel>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Delete Branch:"/>
                <DockPanel Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right" Content="Delete" Command="{Binding DailyDeleteBranchCommand}"
                            Style="{StaticResource DangerButton}" Margin="8,0,0,0" Padding="14,8" FontSize="12"/>
                    <ComboBox Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding AvailableBranches}"
                              SelectedItem="{Binding DeleteBranchName, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFont}" FontSize="12"/>
                </DockPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="List Branches" Command="{Binding DailyListBranchesCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                    <Button Content="Branch Graph" Command="{Binding DailyGraphCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                    <Button Content="Switch to main" Command="{Binding DailySwitchMainCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" FontSize="12"/>
                </StackPanel>

                <TextBlock Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold">Convention:</Run>
                    <Run xml:space="preserve"> Use prefixes like feature/, bugfix/, hotfix/ — e.g. feature/add-export or bugfix/login-timeout.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Stash -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Stash" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,8"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,14"
                           Text="Temporarily save uncommitted changes when you need to switch context. Pop them back when you're ready."/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Stash Message (optional):"/>
                <DockPanel Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right" Content="Stash Save" Command="{Binding DailyStashCommand}"
                            Style="{StaticResource AccentButton}" Margin="8,0,0,0" Padding="14,8" FontSize="12"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding StashMessage, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource MonoFont}"/>
                </DockPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Stash Pop (Restore)" Command="{Binding DailyStashPopCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,0" FontSize="12"/>
                    <Button Content="Stash List" Command="{Binding DailyStashListCommand}"
                            Style="{StaticResource SecondaryButton}" Padding="14,8" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Workflow Guide -->
        <Border Background="#143B82F6" BorderBrush="#4D3B82F6" BorderThickness="1" CornerRadius="8" Padding="18,14">
            <DockPanel>
                <TextBlock Text="i" FontWeight="Bold" Foreground="#FF3B82F6" FontSize="18"
                           DockPanel.Dock="Left" Margin="0,2,14,0" VerticalAlignment="Top"/>
                <StackPanel>
                    <TextBlock Text="Typical daily flow" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" FontSize="13" Margin="0,0,0,10"/>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#FF3B82F6">1.</Run><Run xml:space="preserve">  Pull — get the latest changes from remote</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#FF3B82F6">2.</Run><Run xml:space="preserve">  Make your code changes</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#FF3B82F6">3.</Run><Run xml:space="preserve">  Stage + Commit — save a snapshot with a message</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,5">
                        <Run FontWeight="Bold" Foreground="#FF3B82F6">4.</Run><Run xml:space="preserve">  Push — upload to remote</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap">
                        <Run>Use branches for features that take more than a day.</Run>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </StackPanel>
</UserControl>
