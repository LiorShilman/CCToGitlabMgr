<UserControl x:Class="CCToGitlabMgr.Views.GitLabStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionTitle}">
            <Run Text="05" Foreground="{StaticResource AccentBrush}" FontSize="24"/>
            <Run Text="  Remote — Project Setup"/>
        </TextBlock>
        <TextBlock Style="{StaticResource SectionDesc}" Text="Create an empty project on your remote platform and configure the remote URL."/>

        <!-- Platform Selection -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Remote Platform" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,12"/>
                <TextBlock Foreground="{StaticResource Text2Brush}" FontSize="13" Margin="0,0,0,14"
                           Text="Select the Git hosting platform you will use."/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <RadioButton GroupName="platform" Content="GitLab" FontSize="14" FontWeight="SemiBold"
                                 IsChecked="{Binding Context.RemotePlatform, Converter={StaticResource EqualConv}, ConverterParameter=GitLab}"
                                 Foreground="{StaticResource Text1Brush}" Margin="0,0,24,0" Cursor="Hand"/>
                    <RadioButton GroupName="platform" Content="GitHub" FontSize="14" FontWeight="SemiBold"
                                 IsChecked="{Binding Context.RemotePlatform, Converter={StaticResource EqualConv}, ConverterParameter=GitHub}"
                                 Foreground="{StaticResource Text1Brush}" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Manual Creation Guide -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,16">
                    <Run Text="Create Project in "/><Run Text="{Binding PlatformName, Mode=OneWay}"/>
                </TextBlock>
                <StackPanel Margin="0,0,0,4">
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">1.</Run>
                        <Run>  Log in to your remote platform</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">2.</Run>
                        <Run xml:space="preserve">  Click </Run><Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">New project</Run><Run xml:space="preserve"> > </Run><Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">Create blank project</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">3.</Run>
                        <Run>  Fill in: Project name, Group, Visibility</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">4.</Run>
                        <Run>  </Run><Run Foreground="{StaticResource DangerBrush}" FontWeight="Bold">UNCHECK "Initialize with a README"</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,10">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">5.</Run>
                        <Run xml:space="preserve">  Click </Run><Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">Create project</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,0,4">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentHiBrush}">6.</Run>
                        <Run>  Copy the Clone URL (HTTPS) and paste it below</Run>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Remote URL -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Remote URL" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Text0Brush}" Margin="0,0,0,12"/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Clone URL (HTTPS):"/>
                <TextBox Style="{StaticResource DarkTextBox}" Text="{Binding Context.RemoteUrl, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{StaticResource MonoFont}" Margin="0,0,0,4"/>
                <TextBlock Text="Example: https://gitlab.com/group/project.git  or  https://github.com/user/project.git" Foreground="{StaticResource Text3Brush}" FontSize="11" Margin="0,0,0,16"/>

                <TextBlock Style="{StaticResource FieldLabel}" Text="Authentication Method:"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton GroupName="auth" Content="HTTPS + Token" IsChecked="{Binding Context.AuthMethod, Converter={StaticResource EqualConv}, ConverterParameter=HTTPS}"
                                 Foreground="{StaticResource Text1Brush}" FontSize="13" Margin="0,0,20,0" Cursor="Hand"/>
                    <RadioButton GroupName="auth" Content="SSH Key" IsChecked="{Binding Context.AuthMethod, Converter={StaticResource EqualConv}, ConverterParameter=SSH}"
                                 Foreground="{StaticResource Text1Brush}" FontSize="13" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Danger alert -->
        <Border Background="#14EF4444" BorderBrush="#4DEF4444" BorderThickness="1" CornerRadius="8" Padding="18,14">
            <DockPanel>
                <TextBlock Text="!" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" FontSize="18"
                           DockPanel.Dock="Left" Margin="0,2,14,0" VerticalAlignment="Top"/>
                <StackPanel>
                    <TextBlock Text="Do NOT initialize the repo!" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" FontSize="13" Margin="0,0,0,8"/>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,5">
                        <Run>If the platform creates an auto-README, the remote won't be empty.</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,5">
                        <Run xml:space="preserve">Push will fail with </Run><Run FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource DangerBrush}">"rejected (fetch first)"</Run><Run>.</Run>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource Text1Brush}" FontSize="13" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold">Always create a completely blank project</Run><Run xml:space="preserve"> — uncheck all initialization options.</Run>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </StackPanel>
</UserControl>
