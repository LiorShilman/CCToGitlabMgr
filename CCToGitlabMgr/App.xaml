<Application x:Class="CCToGitlabMgr.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CCToGitlabMgr.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:StepStatusToColorConverter x:Key="StatusToColor"/>
            <conv:EqualityConverter x:Key="EqualConv"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
