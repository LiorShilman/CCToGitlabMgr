<Window x:Class="CCToGitlabMgr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CCToGitlabMgr.Views"
        Title="ClearCase -> GitLab Migration Tool"
        Height="820" Width="1200" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource Bg0Brush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ====== TOP BAR ====== -->
        <Border Grid.ColumnSpan="2" Background="#CC0A0E1A"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="20,12">
                <!-- Brand -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Border Width="38" Height="38" CornerRadius="9" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFE24329" Offset="0"/>
                                <GradientStop Color="#FFFC6D26" Offset="0.5"/>
                                <GradientStop Color="#FFFCA326" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="CC" FontFamily="{StaticResource MonoFont}"
                                   FontWeight="Bold" FontSize="14" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CLEARCASE -> GITLAB" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource Text0Brush}"/>
                        <TextBlock Text="{Binding GitVersion}" FontSize="10"
                                   Foreground="{StaticResource Text3Brush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding BusyMessage}" Foreground="{StaticResource AccentHiBrush}"
                               FontSize="12" Margin="0,0,12,0"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    <Border Width="10" Height="10" CornerRadius="5" Margin="0,0,8,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource AccentColor}"/>
                        </Border.Background>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ====== SIDEBAR ====== -->
        <Border Grid.Row="1" Grid.RowSpan="2" Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Step list -->
                <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Steps}" Margin="0,16,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.GoToStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Number}"
                                    Cursor="Hand" Margin="8,2">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="8" Padding="14,10" Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Step number circle -->
                                                <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,12,0"
                                                        Background="{Binding Status, Converter={StaticResource StatusToColor}}">
                                                    <TextBlock Text="{Binding Number}" FontWeight="Bold" FontSize="12"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text1Brush}"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Version info at bottom -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0 Migration Tool"
                           Foreground="{StaticResource Text3Brush}" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>
            </DockPanel>
        </Border>

        <!-- ====== MAIN CONTENT AREA ====== -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="200" MinHeight="100"/>
            </Grid.RowDefinitions>

            <!-- Step Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,0">
                <Grid>
                    <!-- Step 1: Git Config -->
                    <views:ConfigStepView Visibility="{Binding CurrentStepIndex, Converter={StaticResource EqualConv}, ConverterParameter=0}"/>
                    <!-- Step 2: Prepare -->
                    <views:PrepareStepView Visibility="{Binding CurrentStepIndex, Converter={StaticResource EqualConv}, ConverterParameter=1}"/>
                    <!-- Step 3: Clean -->
                    <views:CleanStepView Visibility="{Binding CurrentStepIndex, Converter={StaticResource EqualConv}, ConverterParameter=2}"/>
                    <!-- Step 4: Gitignore -->
                    <views:GitignoreStepView Visibility="{Binding CurrentStepIndex, Converter={StaticResource EqualConv}, ConverterParameter=3}"/>
                    <!-- Step 5: GitLab -->
                    <views:GitLabStepView Visibility="{Binding CurrentStepIndex, Converter={StaticResource EqualConv}, ConverterParameter=4}"/>
                    <!-- Step 6: Migrate -->
                    <views:MigrateStepView Visibility="{Binding CurrentStepIndex, Converter={StaticResource EqualConv}, ConverterParameter=5}"/>
                    <!-- Step 7: Verify -->
                    <views:VerifyStepView Visibility="{Binding CurrentStepIndex, Converter={StaticResource EqualConv}, ConverterParameter=6}"/>
                    <!-- Step 8: Checklist -->
                    <views:ChecklistStepView Visibility="{Binding CurrentStepIndex, Converter={StaticResource EqualConv}, ConverterParameter=7}"/>
                </Grid>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Height="5"
                          Background="{StaticResource BorderBrush}" Cursor="SizeNS"/>

            <!-- Output Console -->
            <DockPanel Grid.Row="2">
                <Border DockPanel.Dock="Top" Background="{StaticResource Bg2Brush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1"
                        Padding="16,6">
                    <DockPanel>
                        <TextBlock Text="OUTPUT" FontFamily="{StaticResource MonoFont}"
                                   FontSize="11" FontWeight="Bold" Foreground="{StaticResource Text2Brush}"
                                   VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="Clear" HorizontalAlignment="Right"
                                Command="{Binding ClearConsoleCommand}"
                                Style="{StaticResource SecondaryButton}"
                                FontSize="11" Padding="12,4"/>
                    </DockPanel>
                </Border>
                <TextBox Style="{StaticResource ConsoleTextBox}"
                         Text="{Binding ConsoleOutput, Mode=OneWay}"
                         x:Name="ConsoleBox" TextChanged="ConsoleBox_TextChanged"/>
            </DockPanel>
        </Grid>

        <!-- ====== BOTTOM BAR ====== -->
        <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource Bg1Brush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="&lt; Back"
                        Command="{Binding PrevStepCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="16,8"/>

                <Button DockPanel.Dock="Right" Content="Next &gt;"
                        Command="{Binding NextStepCommand}"
                        Style="{StaticResource AccentButton}"
                        Padding="16,8"/>

                <TextBlock Text="{Binding StepProgress}" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource Text2Brush}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
